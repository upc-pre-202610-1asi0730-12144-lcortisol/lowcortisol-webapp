      +string Password
    }

    class UpdateProfileCommand {
      +Guid UserId
      +string FullName
      +string Phone
    }

    class RecoverPasswordCommand {
      +string Email
    }

    class AuthResult {
      +UserDto User
      +AccessProfileDto AccessProfile
