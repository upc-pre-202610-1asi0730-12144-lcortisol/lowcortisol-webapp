' ==========================================================
' SHARED KERNEL
' ==========================================================

package "Shared Kernel" {
  abstract class BaseEntity {
    +Guid Id
    +DateTime CreatedAt
    +DateTime? UpdatedAt
    +void SetCreatedAt()
    +void SetUpdatedAt()
  }

  interface IRepository<T> {
    +Task<IEnumerable<T>> GetAllAsync()
    +Task<T?> GetByIdAsync(Guid id)
    +Task AddAsync(T entity)
    +void Update(T entity)
    +void Delete(T entity)
  }

  interface IUnitOfWork {
    +Task<int> CompleteAsync()
  }

  class ApiResponse<T> {
    +bool Success
    +string Message
    +T Data
    +IEnumerable<string> Errors
  }

  class PagedResult<T> {
    +IEnumerable<T> Items
    +int Page
    +int PageSize
    +int Total
  }

  class DateTimeProvider {
    +DateTime UtcNow()
  }
}

' ==========================================================
' IAM
' ==========================================================

package "IAM Context" {
  package "Domain" {
    class User {
      +Guid Id
      +string FullName
      +string Email
      +string Phone
      +string PasswordHash
      +string Status
      +Guid AccessProfileId
      +void Activate()
      +void Deactivate()
      +void UpdateProfile(string fullName, string phone)
    }

    class AccessProfile {
      +Guid Id
      +string Name
      +string Role
      +ICollection<Permission> Permissions
      +bool HasPermission(string code)
    }

    class Permission {
      +Guid Id
      +string Code
      +string Description
    }

    class AuthSession {
      +Guid Id
      +Guid UserId
      +string Token
      +string RefreshToken
      +bool IsActive
      +DateTime ExpiresAt
      +void Revoke()
      +bool IsExpired()
    }

    interface IUserRepository {
      +Task<User?> FindByEmailAsync(string email)
