' IAM
' ==========================================================

package "iam" {
  package "domain" {
    class User {
      +Guid Id
      +string FullName
      +string Email
      +string Phone
      +string PasswordHash
      +string Status
      +Guid AccessProfileId
      +void Activate()
      +void Deactivate()
      +void UpdateProfile(string fullName, string phone)
    }

    class AccessProfile {
      +Guid Id
      +string Name
      +string Role
      +ICollection<Permission> Permission
      +bool HasPermission(string code)
    }

    class Permission {
      +Guid Id
      +string Code
      +string Description
    }

    class AuthSession {
      +Guid Id
      +Guid UserId
      +string Token
      +string RefreshToken
      +bool IsActive
      +DateTime ExpiresAt
      +void Revoke()
      +bool IsExpired()
    }

    interface UserRepository {
      +Task<User?> FindByEmailAsync(string email)
      +Task<User?> FindByIdAsync(Guid id)
