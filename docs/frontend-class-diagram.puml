@startuml
title LowCortisol Platform - Frontend Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #1F2937
  ArrowColor #1F2937
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #CBD5E1
}
skinparam note {
  BackgroundColor #EFF6FF
  BorderColor #60A5FA
}

' =========================
' SHARED
' =========================
package "shared" {
  package "presentation/components" {
    class AppLayout <<Vue Component>> {
      +render()
      +hideNavigation
    }

    class BottomNavigation <<Vue Component>> {
      +items
      +render()
    }

    class LanguageSwitcher <<Vue Component>> {
      +languages
      +handleLanguageChange(language)
    }

    class UiCard <<Vue Component>> {
      +title
      +compact
      +render()
    }
  }

  package "application/services" {
    class TranslationService {
      +initialize()
      +setLanguage(language)
      +getLanguage()
      +translate(key)
    }

    class AuthSessionService {
      +signIn(user)
      +signOut()
      +isAuthenticated()
      +getCurrentUser()
      +setCurrentUser(user)
    }

    class SubscriptionAccessService {
      +hasActiveSubscription()
      +getActiveSubscription()
    }

    class ThemeService {
      +initialize()
      +setTheme(theme)
      +getTheme()
    }
  }

  package "infrastructure/http" {
    class ApiClientService {
      +get(path, query)
      +post(path, body)
      +patch(path, body)
      +put(path, body)
      +delete(path)
    }
  }

  package "router" {
    class RouterGuard {
      +beforeEach(to)
      +requiresAuth
      +requiresSubscription
    }
  }
}

' =========================
' IAM
' =========================
package "iam" {
  package "presentation/pages" {
    class LoginPage <<Vue Page>> {
      +form
      +handleSubmit()
    }

    class RegisterPage <<Vue Page>> {
      +form
      +handleSubmit()
    }

    class RecoverPasswordPage <<Vue Page>> {
      +form
      +handleSubmit()
    }

    class ProfilePage <<Vue Page>> {
      +form
      +handleSaveProfile()
      +handleSignOut()
    }
  }

  package "application/store" {
    class IamStore {
      +state
      +signIn(payload)
      +signUp(payload)
      +recoverPassword(payload)
      +loadSession()
      +updateProfile(payload)
      +signOut()
    }
  }

  package "application/services" {
    class IamFacade {
      -iamApiService
      +signIn(payload)
      +signUp(payload)
      +recoverPassword(payload)
      +getProfile()
      +getAccessProfile()
      +getSession()
      +updateProfile(payload)
      +signOut()
    }
  }

  package "infrastructure/api" {
    class IamApiService {
      +signIn(payload)
      +signUp(payload)
      +recoverPassword(payload)
      +getProfile()
      +getAccessProfile()
      +getSession()
      +updateProfile(payload)
      +signOut()
    }
  }

  package "domain/model" {
    class User {
      +id
      +fullName
      +email
      +phone
      +status
      +accessProfileId
      +initials
      +statusLabel
    }

    class AccessProfile {
      +id
      +name
      +role
      +permissions
      +roleLabel
    }

    class AuthSession {
      +id
      +userId
      +token
      +isActive
      +canAccess
    }
  }
}

' =========================
' PLANS
' =========================
package "plans" {
  package "presentation/pages" {
    class PlansPage <<Vue Page>> {
      +selectedPlan
      +checkout
      +openCheckout(plan)
      +closeCheckout()
      +handlePurchase()
      +handleCardNumberInput(event)
      +handleExpirationDateInput(event)
      +handleSecurityCodeInput(event)
    }
  }

  package "presentation/components" {
    class PlanCard <<Vue Component>> {
      +plan
      +active
      +getPriceLabel(price)
      +getBillingPeriodLabel(period)
      +emitBuy(plan)
    }
  }

  package "application/store" {
    class PlansStore {
      +state
      +loadPlansPage()
      +subscribeToPlan(planId)
      +changePlan(planId)
      +cancelSubscription()
      +getActivePlan()
    }
  }

  package "application/services" {
    class PlansFacade {
      -plansApiService
      +getPlans()
      +getPlanById(planId)
      +getActiveSubscription()
      +subscribe(payload)
      +changePlan(payload)
      +cancelSubscription(payload)
      +getPayments()
      +getServiceRequests()
      +getSummary()
    }
  }

  package "infrastructure/api" {
    class PlansApiService {
      +getPlans()
      +getPlanById(planId)
      +getActiveSubscription()
      +subscribe(payload)
      +changePlan(payload)
      +cancelSubscription(payload)
      +getPayments()
      +getServiceRequests()
      +getSummary()
    }
  }

  package "domain/model" {
    class Plan {
      +id
      +name
      +code
      +description
      +price
      +currency
      +billingPeriod
      +maxSites
      +maxDevices
      +recommended
      +features
    }

    class PlanFeature {
      +id
      +planId
      +name
      +description
      +included
    }

    class Subscription {
      +id
      +userId
      +workplaceId
      +planId
      +status
      +startedAt
      +autoRenew
    }

    class Payment {
      +id
      +subscriptionId
      +amount
      +currency
      +method
      +status
      +paidAt
    }

    class ServiceRequest {
      +id
      +subscriptionId
      +type
      +description
      +status
    }
  }
}

' =========================
' WORKPLACE
' =========================
package "workplace" {
  package "presentation/pages" {
    class SitesPage <<Vue Page>> {
      +selectedType
      +selectedSite
      +handleFilterChange(type)
      +handleCreateSite()
      +handleAssignMember()
      +handleAssignDevice()
    }
  }

  package "presentation/components" {
    class SiteFilter <<Vue Component>> {
      +modelValue
      +options
      +emitUpdateModelValue(value)
    }
  }

  package "application/store" {
    class WorkplaceStore {
      +state
      +loadWorkplace()
      +filterSitesByType(type)
      +selectSite(siteId)
      +createSite(payload)
      +assignMemberToSite(payload)
      +assignDeviceToSite(payload)
      +getSelectedSite()
    }
  }

  package "application/services" {
    class WorkplaceFacade {
      -workplaceApiService
      +getWorkplace()
      +getSites(type)
      +getSiteById(siteId)
      +createSite(payload)
      +assignMemberToSite(payload)
      +assignDeviceToSite(payload)
      +getMembersBySite(siteId)
      +getAssignmentsBySite(siteId)
      +getSummary()
    }
  }

  package "infrastructure/api" {
    class WorkplaceApiService {
      +getWorkplace()
      +getSites(type)
      +getSiteById(siteId)
      +createSite(payload)
      +assignMemberToSite(payload)
      +assignDeviceToSite(payload)
      +getMembersBySite(siteId)
      +getAssignmentsBySite(siteId)
      +getSummary()
    }
  }

  package "domain/model" {
    class Workplace {
      +id
      +ownerId
      +name
      +description
    }

    class Site {
      +id
      +workplaceId
      +name
      +address
      +type
      +status
      +waterConsumption
      +gasConsumption
      +activeSensors
      +activeIncidents
    }

    class SiteMember {
      +id
      +siteId
      +userId
      +fullName
      +email
      +role
    }

    class SiteDeviceAssignment {
      +id
      +siteId
      +deviceId
      +deviceName
      +deviceType
      +status
    }
  }
}

' =========================
' DEVICE CONTROL
' =========================
package "device-control" {
  package "presentation/pages" {
    class DevicesPage <<Vue Page>> {
      +selectedDevice
      +selectedDeviceSensors
      +selectedDeviceValves
      +handleCreateDevice()
      +handleLinkSensor()
      +handleExecuteCommand()
    }
  }

  package "presentation/components" {
    class DeviceCard <<Vue Component>> {
      +device
      +active
      +getDeviceTypeLabel(type)
      +getStatusLabel(status)
    }

    class SensorCard <<Vue Component>> {
      +sensor
      +getResourceLabel(resourceType)
    }

    class ValveControl <<Vue Component>> {
      +valve
      +getResourceLabel(resourceType)
      +getStatusLabel(status)
      +emitOpen(id)
      +emitClose(id)
    }
  }

  package "application/store" {
    class DeviceControlStore {
      +state
      +loadDevicesPage()
      +selectDevice(deviceId)
      +getSelectedDevice()
      +createDevice(payload)
      +linkSensor(payload)
      +closeValve(valveId)
      +openValve(valveId)
      +executeSyncCommand(deviceId)
    }
  }

  package "application/services" {
    class DeviceControlFacade {
      -deviceControlApiService
      +getDevices()
      +createDevice(payload)
      +linkSensor(payload)
      +closeValve(valveId)
      +openValve(valveId)
      +executeSyncCommand(deviceId)
      +getCommands()
      +getSummary()
    }
  }

  package "infrastructure/api" {
    class DeviceControlApiService {
      +getDevices()
      +createDevice(payload)
      +linkSensor(payload)
      +closeValve(valveId)
      +openValve(valveId)
      +executeSyncCommand(deviceId)
      +getCommands()
      +getSummary()
    }
  }

  package "domain/model" {
    class Device {
      +id
      +siteId
      +name
      +type
      +status
      +isOnline
      +sensors
      +valves
      +commands
    }

    class Sensor {
      +id
      +deviceId
      +siteId
      +name
      +resourceType
      +currentValue
      +unit
      +threshold
      +status
      +hasExceededThreshold
    }

    class Valve {
      +id
      +deviceId
      +siteId
      +name
      +resourceType
      +status
      +openingPercentage
      +isOpen
    }

    class DeviceCommand {
      +id
      +deviceId
      +commandType
      +status
      +createdAt
    }
  }
}

' =========================
' MONITORING
' =========================
package "monitoring" {
  package "presentation/pages" {
    class DashboardPage <<Vue Page>> {
      +createRandomReading()
      +getSeverityLabel(severity)
      +getStatusLabel(status)
    }

    class ReportsPage <<Vue Page>> {
      +handleCreateReport()
      +getStatusClass(status)
      +getResourceLabel(resourceType)
      +getPeriodLabel(period)
    }
  }

  package "presentation/components" {
    class MetricCard <<Vue Component>> {
      +label
      +value
      +hint
    }

    class UsageChart <<Vue Component>> {
      +items
      +getWidth(value)
      +getResourceLabel(resourceType)
    }
  }

  package "application/store" {
    class MonitoringStore {
      +state
      +loadDashboard()
      +createRandomReading()
      +createReport(siteId)
    }
  }

  package "application/services" {
    class MonitoringFacade {
      -monitoringApiService
      +getSummary()
      +getActiveSession()
      +getReadings()
      +getAnomalies()
      +createRandomReading()
      +getReports()
      +createReport(siteId)
    }
  }

  package "infrastructure/api" {
    class MonitoringApiService {
      +getSummary()
      +getActiveSession()
      +getReadings()
      +getAnomalies()
      +createRandomReading()
      +getReports()
      +createReport(siteId)
    }
  }

  package "domain/model" {
    class MonitoringSession {
      +id
      +isActive
      +totalReadings
      +totalAnomalies
      +startedAt
    }

    class Reading {
      +id
      +sensorId
      +siteId
      +resourceType
      +value
      +unit
      +status
      +measuredAt
    }

    class Anomaly {
      +id
      +readingId
      +siteId
      +severity
      +description
      +status
    }

    class Report {
      +id
      +siteId
      +period
      +totalWater
      +totalGas
      +anomaliesCount
    }
  }
}

' =========================
' NOTIFICATIONS
' =========================
package "notifications" {
  package "presentation/pages" {
    class AlertsPage <<Vue Page>> {
      +handleCreateAlert()
      +handleCreateThreshold()
      +getPriorityClass(priority)
      +getPriorityLabel(priority)
    }
  }

  package "presentation/components" {
    class AlertCard <<Vue Component>> {
      +alert
      +severityClass
      +getSeverityLabel(severity)
      +getStatusLabel(status)
      +emitResolve(id)
      +emitClose(id)
      +emitSend(id)
    }

    class ThresholdCard <<Vue Component>> {
      +threshold
      +getResourceLabel(resourceType)
    }
  }

  package "application/store" {
    class NotificationsStore {
      +state
      +loadAlertsPage()
      +createAlert(payload)
      +resolveAlert(alertId)
      +closeAlert(alertId)
      +createThreshold(payload)
      +sendAlert(alertId)
    }
  }

  package "application/services" {
    class NotificationsFacade {
      -notificationsApiService
      +getAlerts()
      +createAlert(payload)
      +resolveAlert(alertId)
      +closeAlert(alertId)
      +getThresholds()
      +createThreshold(payload)
      +getIncidents()
      +getNotificationChannels()
      +getAlertDeliveries()
      +sendAlert(alertId)
      +getSummary()
    }
  }

  package "infrastructure/api" {
    class NotificationsApiService {
      +getAlerts()
      +createAlert(payload)
      +resolveAlert(alertId)
      +closeAlert(alertId)
      +getThresholds()
      +createThreshold(payload)
      +getIncidents()
      +getNotificationChannels()
      +getAlertDeliveries()
      +sendAlert(alertId)
      +getSummary()
    }
  }

  package "domain/model" {
    class Alert {
      +id
      +siteId
      +sensorId
      +resourceType
      +title
      +description
      +severity
      +status
    }

    class Threshold {
      +id
      +siteId
      +sensorId
      +resourceType
      +warningLimit
      +criticalLimit
      +unit
      +enabled
    }

    class Incident {
      +id
      +alertId
      +siteId
      +title
      +description
      +priority
      +status
      +assignedTo
    }

    class NotificationChannel {
      +id
      +name
      +type
      +destination
      +enabled
    }

    class AlertDelivery {
      +id
      +alertId
      +channelId
      +status
      +sentAt
    }
  }
}

' =========================
' SUPPORT
' =========================
package "support" {
  package "presentation/pages" {
    class SupportPage <<Vue Page>> {
      +messageContent
      +selectedTicket
      +selectedConversation
      +handleCreateTicket()
      +handleSendMessage()
      +getStatusLabel(status)
      +getSenderTypeLabel(senderType)
    }
  }

  package "presentation/components" {
    class SupportTicketCard <<Vue Component>> {
      +ticket
      +active
      +priorityClass
      +getCategoryLabel(category)
      +getPriorityLabel(priority)
      +getStatusLabel(status)
    }

    class KnowledgeArticleCard <<Vue Component>> {
      +article
      +getCategoryLabel(category)
    }
  }

  package "application/store" {
    class SupportStore {
      +state
      +loadSupportPage()
      +selectTicket(ticketId)
      +getSelectedTicket()
      +getSelectedConversation()
      +createTicket(payload)
      +resolveTicket(ticketId)
      +closeTicket(ticketId)
      +sendMessage(content)
    }
  }

  package "application/services" {
    class SupportFacade {
      -supportApiService
      +getTickets()
      +createTicket(payload)
      +resolveTicket(ticketId)
      +closeTicket(ticketId)
      +sendMessage(payload)
      +getAgents()
      +getArticles()
      +getConversations()
      +getSummary()
    }
  }

  package "infrastructure/api" {
    class SupportApiService {
      +getTickets()
      +createTicket(payload)
      +resolveTicket(ticketId)
      +closeTicket(ticketId)
      +sendMessage(payload)
      +getAgents()
      +getArticles()
      +getConversations()
      +getSummary()
    }
  }

  package "domain/model" {
    class SupportTicket {
      +id
      +userId
      +siteId
      +title
      +description
      +category
      +priority
      +status
      +assignedAgentId
      +messages
    }

    class SupportMessage {
      +id
      +ticketId
      +senderId
      +senderType
      +content
      +status
    }

    class SupportAgent {
      +id
      +fullName
      +email
      +specialty
      +status
    }

    class SupportConversation {
      +id
      +ticketId
      +status
      +messages
    }

    class KnowledgeArticle {
      +id
      +title
      +summary
      +category
      +content
      +helpfulCount
    }
  }
}

' =========================
' GENERAL DEPENDENCIES
' =========================

AppLayout --> BottomNavigation
AppLayout --> LanguageSwitcher
AppLayout --> UiCard

BottomNavigation --> TranslationService
LanguageSwitcher --> TranslationService
RouterGuard --> AuthSessionService
RouterGuard --> SubscriptionAccessService
SubscriptionAccessService --> ApiClientService
SubscriptionAccessService --> AuthSessionService

' IAM dependencies
LoginPage --> AppLayout
LoginPage --> UiCard
LoginPage --> IamStore
LoginPage --> TranslationService

RegisterPage --> AppLayout
RegisterPage --> UiCard
RegisterPage --> IamStore
RegisterPage --> TranslationService

RecoverPasswordPage --> AppLayout
RecoverPasswordPage --> UiCard
RecoverPasswordPage --> IamStore
RecoverPasswordPage --> TranslationService

ProfilePage --> AppLayout
ProfilePage --> UiCard
ProfilePage --> IamStore
ProfilePage --> TranslationService

IamStore --> IamFacade
IamFacade --> IamApiService
IamApiService --> ApiClientService
IamApiService --> AuthSessionService
IamApiService ..> User
IamApiService ..> AccessProfile
IamApiService ..> AuthSession

User --> AccessProfile : accessProfileId

' Plans dependencies
PlansPage --> AppLayout
PlansPage --> UiCard
PlansPage --> PlanCard
PlansPage --> PlansStore
PlansPage --> TranslationService

PlanCard --> TranslationService
PlansStore --> PlansFacade
PlansFacade --> PlansApiService
PlansApiService --> ApiClientService
PlansApiService --> AuthSessionService

Plan "1" o-- "*" PlanFeature
Subscription --> Plan : planId
Payment --> Subscription : subscriptionId
ServiceRequest --> Subscription : subscriptionId

' Workplace dependencies
SitesPage --> AppLayout
SitesPage --> UiCard
SitesPage --> SiteFilter
SitesPage --> WorkplaceStore
SitesPage --> TranslationService

SiteFilter --> TranslationService
WorkplaceStore --> WorkplaceFacade
WorkplaceFacade --> WorkplaceApiService
WorkplaceApiService --> ApiClientService

Workplace "1" o-- "*" Site
Site "1" o-- "*" SiteMember
Site "1" o-- "*" SiteDeviceAssignment

' Device dependencies
DevicesPage --> AppLayout
DevicesPage --> UiCard
DevicesPage --> DeviceCard
DevicesPage --> SensorCard
DevicesPage --> ValveControl
DevicesPage --> DeviceControlStore
DevicesPage --> TranslationService

DeviceCard --> TranslationService
SensorCard --> TranslationService
ValveControl --> TranslationService

DeviceControlStore --> DeviceControlFacade
DeviceControlFacade --> DeviceControlApiService
DeviceControlApiService --> ApiClientService

Device "1" o-- "*" Sensor
Device "1" o-- "*" Valve
Device "1" o-- "*" DeviceCommand
Device --> Site : siteId

' Monitoring dependencies
DashboardPage --> AppLayout
DashboardPage --> UiCard
DashboardPage --> MetricCard
DashboardPage --> UsageChart
DashboardPage --> MonitoringStore
DashboardPage --> TranslationService

ReportsPage --> AppLayout
ReportsPage --> UiCard
ReportsPage --> MetricCard
ReportsPage --> MonitoringStore
ReportsPage --> TranslationService

UsageChart --> TranslationService
MonitoringStore --> MonitoringFacade
MonitoringFacade --> MonitoringApiService
MonitoringApiService --> ApiClientService

MonitoringSession "1" o-- "*" Reading
Reading "1" --> "0..1" Anomaly
Report --> Site : siteId
Reading --> Sensor : sensorId

' Notifications dependencies
AlertsPage --> AppLayout
AlertsPage --> UiCard
AlertsPage --> AlertCard
AlertsPage --> ThresholdCard
AlertsPage --> NotificationsStore
AlertsPage --> TranslationService

AlertCard --> TranslationService
ThresholdCard --> TranslationService

NotificationsStore --> NotificationsFacade
NotificationsFacade --> NotificationsApiService
NotificationsApiService --> ApiClientService

Alert "1" --> "0..*" Incident
Alert "1" --> "0..*" AlertDelivery
Threshold --> Sensor : sensorId
AlertDelivery --> NotificationChannel : channelId

' Support dependencies
SupportPage --> AppLayout
SupportPage --> UiCard
SupportPage --> SupportTicketCard
SupportPage --> KnowledgeArticleCard
SupportPage --> SupportStore
SupportPage --> TranslationService

SupportTicketCard --> TranslationService
KnowledgeArticleCard --> TranslationService

SupportStore --> SupportFacade
SupportFacade --> SupportApiService
SupportApiService --> ApiClientService
SupportApiService --> AuthSessionService

SupportTicket "1" o-- "*" SupportMessage
SupportConversation --> SupportTicket : ticketId
SupportTicket --> SupportAgent : assignedAgentId
SupportTicket --> Site : siteId

' Cross-context relations
User --> Subscription : userId
User --> SiteMember : userId
User --> SupportTicket : userId

Site --> Device : siteId
Site --> Reading : siteId
Site --> Alert : siteId
Site --> Incident : siteId
Site --> SupportTicket : siteId

Sensor --> Reading : sensorId
Sensor --> Alert : sensorId
Sensor --> Threshold : sensorId

@enduml