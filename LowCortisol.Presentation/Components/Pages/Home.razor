@page "/home"
@implements IDisposable
@rendermode InteractiveServer
@inject LowCortisol.Application.Contexts.IdentityAccess.Services.IIdentityAccessService IdentityAccessService
@inject LowCortisol.Infrastructure.Security.CurrentUserSession CurrentUserSession
@inject LowCortisol.Presentation.Services.BrowserSessionService BrowserSession
@inject LowCortisol.Presentation.Services.UiSessionService Session
@inject LowCortisol.Presentation.Services.I18nService I18n
@inject NavigationManager Nav

@if (!Session.IsAuthenticated || Session.CurrentUser is null)
{
    <div class="soft-card section-card">
        <h1 class="page-title">@I18n["common.loading"]</h1>
    </div>
}
else
{
    <div>
        <h1 class="page-title">@I18n["home.title"]</h1>
        <p class="page-subtitle">@I18n["home.welcome"], @Session.CurrentUser.Name</p>

        <div class="dashboard-grid">
            <div class="soft-card section-card metric-card desktop-span-4">
                <div>
                    <div class="section-heading">@I18n["home.water"]</div>
                    <p class="page-subtitle">@I18n["home.currentConsumption"]</p>
                </div>
                <div class="metric-value">245 L</div>
            </div>

            <div class="soft-card section-card metric-card desktop-span-4">
                <div>
                    <div class="section-heading">@I18n["home.gas"]</div>
                    <p class="page-subtitle">@I18n["home.currentConsumption"]</p>
                </div>
                <div class="metric-value">84 m³</div>
            </div>

            <div class="soft-card section-card metric-card desktop-span-4">
                <div>
                    <div class="section-heading">@I18n["home.activeIncidents"]</div>
                    <p class="page-subtitle">@I18n["home.alertsReview"]</p>
                </div>
                <div class="metric-value">3</div>
            </div>

            <div class="soft-card section-card desktop-span-8">
                <h2 class="section-heading">@I18n["home.systemOverview"]</h2>
                <div class="data-list">
                    <div class="data-row">
                        <span>@I18n["home.registeredDevices"]</span>
                        <strong>12</strong>
                    </div>
                    <div class="data-row">
                        <span>@I18n["home.connectedSensors"]</span>
                        <strong>28</strong>
                    </div>
                    <div class="data-row">
                        <span>@I18n["home.notificationsToday"]</span>
                        <strong>16</strong>
                    </div>
                    <div class="data-row">
                        <span>@I18n["home.reportsWeek"]</span>
                        <strong>5</strong>
                    </div>
                </div>
            </div>

            <div class="soft-card section-card desktop-span-4">
                <h2 class="section-heading">@I18n["home.quickActions"]</h2>
                <div class="data-list">
                    <a class="quick-action-btn" href="/devices">@I18n["home.manageDevices"]</a>
                    <a class="quick-action-btn" href="/reports">@I18n["home.openReports"]</a>
                    <a class="quick-action-btn" href="/alerts">@I18n["home.reviewAlerts"]</a>
                    <a class="quick-action-btn" href="/profile">@I18n["home.viewProfile"]</a>
                </div>
            </div>

            <div class="soft-card section-card desktop-span-6">
                <h2 class="section-heading">@I18n["home.latestIncidents"]</h2>
                <div class="data-list">
                    <div class="status-card">
                        <div class="status-top">
                            <strong>@I18n["home.pressureAnomaly"]</strong>
                            <span class="status-pill status-high">@I18n["status.high"]</span>
                        </div>
                        <p>@I18n["home.pressureAnomalyDesc"]</p>
                    </div>

                    <div class="status-card">
                        <div class="status-top">
                            <strong>@I18n["home.gasLeakWarning"]</strong>
                            <span class="status-pill status-critical">@I18n["status.critical"]</span>
                        </div>
                        <p>@I18n["home.gasLeakWarningDesc"]</p>
                    </div>
                </div>
            </div>

            <div class="soft-card section-card desktop-span-6">
                <h2 class="section-heading">@I18n["home.recentNotifications"]</h2>
                <div class="data-list">
                    <div class="status-card">
                        <div class="status-top">
                            <strong>@I18n["home.emailDispatch"]</strong>
                            <span class="status-pill status-ok">@I18n["status.sent"]</span>
                        </div>
                        <p>@I18n["home.emailDispatchDesc"]</p>
                    </div>

                    <div class="status-card">
                        <div class="status-top">
                            <strong>@I18n["home.smsFallback"]</strong>
                            <span class="status-pill status-pending">@I18n["status.pending"]</span>
                        </div>
                        <p>@I18n["home.smsFallbackDesc"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _checkedSession;

    protected override void OnInitialized()
    {
        I18n.OnChange += RefreshLanguage;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedSession)
            return;

        _checkedSession = true;

        if (!Session.IsAuthenticated || Session.CurrentUser is null)
        {
            var storedUserId = await BrowserSession.GetUserIdAsync();

            if (storedUserId is null)
            {
                Nav.NavigateTo("/", forceLoad: true);
                return;
            }

            var user = await IdentityAccessService.GetByIdAsync(storedUserId.Value);

            if (user is null)
            {
                await BrowserSession.ClearAsync();
                Nav.NavigateTo("/", forceLoad: true);
                return;
            }

            CurrentUserSession.SignIn(user.Id);
            Session.SignIn(user);
        }

        await InvokeAsync(StateHasChanged);
    }

    private void RefreshLanguage()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        I18n.OnChange -= RefreshLanguage;
    }
}