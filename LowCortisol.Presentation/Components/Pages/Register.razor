@page "/register"
@implements IDisposable
@rendermode InteractiveServer
@inject LowCortisol.Presentation.Services.BrowserSessionService BrowserSession
@inject LowCortisol.Application.Contexts.IdentityAccess.Services.IIdentityAccessService IdentityAccessService
@inject LowCortisol.Infrastructure.Security.CurrentUserSession CurrentUserSession
@inject LowCortisol.Presentation.Services.UiSessionService Session
@inject LowCortisol.Presentation.Services.I18nService I18n
@inject NavigationManager Nav

<div class="auth-wrap">
    <div class="soft-card auth-card">
        <h1 class="page-title">@I18n["auth.register.title"]</h1>
        <p class="page-subtitle">@I18n["auth.register.subtitle"]</p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.name"]</label>
            <input class="auth-input"
                   @bind="name"
                   @bind:event="oninput"
                   placeholder="Jean Franck Loa Rojas" />
        </div>

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.email"]</label>
            <input class="auth-input"
                   @bind="email"
                   @bind:event="oninput"
                   placeholder="you@example.com" />
        </div>

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.phone"]</label>
            <input class="auth-input"
                   @bind="phone"
                   @bind:event="oninput"
                   placeholder="+51 999 999 999" />
        </div>

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.password"]</label>
            <input class="auth-input"
                   type="password"
                   @bind="password"
                   @bind:event="oninput"
                   placeholder="Create a password" />
        </div>

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.accountType"]</label>
            <select class="auth-select" @bind="role">
                <option value="Homeowner">Homeowner</option>
                <option value="Admin">Admin</option>
                <option value="Technician">Technician</option>
            </select>
        </div>

        <button class="primary-btn" @onclick="RegisterAsync">
            @I18n["auth.create"]
        </button>

        <a class="secondary-link" href="/">
            @I18n["auth.back"]
        </a>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private string phone = string.Empty;
    private string password = string.Empty;
    private string role = "Homeowner";
    private string errorMessage = string.Empty;
    private bool isSubmitting;
    private bool _checkedSession;

    protected override void OnInitialized()
    {
        I18n.OnChange += RefreshLanguage;
    }

    private void RefreshLanguage()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        I18n.OnChange -= RefreshLanguage;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedSession)
            return;

        _checkedSession = true;

        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/home", forceLoad: true);
            return;
        }

        var storedUserId = await BrowserSession.GetUserIdAsync();
        if (storedUserId is null)
            return;

        var user = await IdentityAccessService.GetByIdAsync(storedUserId.Value);
        if (user is null)
        {
            await BrowserSession.ClearAsync();
            return;
        }

        CurrentUserSession.SignIn(user.Id);
        Session.SignIn(user);

        Nav.NavigateTo("/home", forceLoad: true);
    }

    private async Task RegisterAsync()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        errorMessage = string.Empty;

        try
        {
            var registerResult = await IdentityAccessService.RegisterAsync(
                new LowCortisol.Application.Contexts.IdentityAccess.Commands.RegisterUserCommand
                {
                    Name = name,
                    Email = email,
                    Phone = phone,
                    Password = password,
                    Role = role
                });

            if (!registerResult.Success)
            {
                errorMessage = string.IsNullOrWhiteSpace(registerResult.Error)
                    ? "Unable to register."
                    : registerResult.Error;
                return;
            }

            var loginResult = await IdentityAccessService.LoginAsync(
                new LowCortisol.Application.Contexts.IdentityAccess.Commands.LoginUserCommand
                {
                    Email = email,
                    Password = password
                });

            if (!loginResult.Success || loginResult.User is null)
            {
                errorMessage = string.IsNullOrWhiteSpace(loginResult.Error)
                    ? "Registration succeeded, but automatic login failed."
                    : loginResult.Error;
                return;
            }

            CurrentUserSession.SignIn(loginResult.User.Id);
            Session.SignIn(loginResult.User);
            await BrowserSession.SaveUserIdAsync(loginResult.User.Id);

            Nav.NavigateTo("/home", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}