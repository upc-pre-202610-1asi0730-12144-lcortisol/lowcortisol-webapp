@page "/devices"
@implements IDisposable
@rendermode InteractiveServer
@inject LowCortisol.Application.Contexts.IdentityAccess.Services.IIdentityAccessService IdentityAccessService
@inject LowCortisol.Infrastructure.Security.CurrentUserSession CurrentUserSession
@inject LowCortisol.Presentation.Services.BrowserSessionService BrowserSession
@inject LowCortisol.Application.Contexts.DeviceManagement.Services.IDeviceManagementService DeviceManagementService
@inject LowCortisol.Presentation.Services.UiSessionService Session
@inject LowCortisol.Presentation.Services.I18nService I18n
@inject NavigationManager Nav

@if (isLoadingPage)
{
    <div class="soft-card section-card">
        <h1 class="page-title">@I18n["common.loading"]</h1>
    </div>
}
else if (!string.IsNullOrWhiteSpace(fatalError))
{
    <div class="soft-card section-card">
        <h1 class="page-title">@I18n["devices.title"]</h1>
        <div class="error-box">@fatalError</div>
    </div>
}
else
{
    <div>
        <div class="page-header-row">
            <div>
                <h1 class="page-title">@I18n["devices.title"]</h1>
                <p class="page-subtitle">@I18n["devices.subtitle"]</p>
            </div>

            <button class="primary-btn page-header-btn" @onclick="OpenCreatePanel">
                @I18n["devices.add"]
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        @if (showCreatePanel)
        {
            <div class="soft-card section-card create-panel">
                <h2 class="section-heading">@I18n["devices.register"]</h2>

                <div class="form-grid">
                    <div class="auth-field">
                        <label class="auth-label">@I18n["common.name"]</label>
                        <input class="auth-input" @bind="newDeviceName" @bind:event="oninput" placeholder="Main water valve" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">@I18n["common.type"]</label>
                        <select class="auth-select" @bind="newDeviceType">
                            <option value="SmartValve">SmartValve</option>
                            <option value="LeakSensor">LeakSensor</option>
                            <option value="TemperatureSensor">TemperatureSensor</option>
                            <option value="PressureGauge">PressureGauge</option>
                            <option value="Hub">Hub</option>
                        </select>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">@I18n["common.status"]</label>
                        <select class="auth-select" @bind="newDeviceStatus">
                            <option value="Online">@I18n["status.online"]</option>
                            <option value="Offline">@I18n["status.offline"]</option>
                            <option value="Maintenance">@I18n["status.maintenance"]</option>
                        </select>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">@I18n["common.location"]</label>
                        <input class="auth-input" @bind="newDeviceLocation" @bind:event="oninput" placeholder="Kitchen" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">@I18n["devices.thresholdValue"]</label>
                        <input class="auth-input" type="number" step="0.1" @bind="newThresholdValue" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">@I18n["devices.thresholdUnit"]</label>
                        <input class="auth-input" @bind="newThresholdUnit" @bind:event="oninput" placeholder="bar / L/min / ppm" />
                    </div>
                </div>

                <div class="panel-actions">
                    <button class="secondary-btn" @onclick="CloseCreatePanel">@I18n["common.cancel"]</button>
                    <button class="primary-btn panel-primary" @onclick="CreateDeviceAsync">@I18n["devices.saveDevice"]</button>
                </div>
            </div>
        }

        <div class="devices-grid">
            @if (devices.Count == 0)
            {
                <div class="soft-card section-card desktop-span-12">
                    <h2 class="section-heading">@I18n["devices.noDevices"]</h2>
                    <p class="page-subtitle">@I18n["devices.noDevicesDesc"]</p>
                </div>
            }
            else
            {
                @foreach (var device in devices)
                {
                    <div class="soft-card section-card device-card">
                        <div class="device-card-top">
                            <div>
                                <h2 class="device-card-title">@device.Name</h2>
                                <p class="device-card-subtitle">@device.Type · @device.Location</p>
                            </div>

                            <span class="@GetStatusClass(device.Status)">
                                @TranslateDeviceStatus(device.Status)
                            </span>
                        </div>

                        <div class="device-card-metrics">
                            <div class="device-metric">
                                <span class="device-metric-label">@I18n["devices.sensors"]</span>
                                <strong>@device.SensorsCount</strong>
                            </div>

                            <div class="device-metric">
                                <span class="device-metric-label">@I18n["devices.threshold"]</span>
                                <strong>@FormatThreshold(device)</strong>
                            </div>
                        </div>

                        <div class="device-card-actions">
                            <button class="secondary-btn" @onclick='() => ChangeStatusAsync(device.Id, "Online")'>@I18n["devices.setOnline"]</button>
                            <button class="secondary-btn" @onclick='() => ChangeStatusAsync(device.Id, "Offline")'>@I18n["devices.setOffline"]</button>
                            <button class="secondary-btn" @onclick='() => ChangeStatusAsync(device.Id, "Maintenance")'>@I18n["devices.maintenance"]</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private List<LowCortisol.Application.Contexts.DeviceManagement.DTOs.DeviceDto> devices = new();
    private bool showCreatePanel;
    private bool isSubmitting;
    private string errorMessage = string.Empty;
    private string fatalError = string.Empty;
    private bool _checkedSession;
    private bool isLoadingPage = true;

    private string newDeviceName = string.Empty;
    private string newDeviceType = "SmartValve";
    private string newDeviceStatus = "Online";
    private string newDeviceLocation = string.Empty;
    private decimal? newThresholdValue;
    private string? newThresholdUnit;

    protected override void OnInitialized()
    {
        I18n.OnChange += RefreshLanguage;
    }

    private void RefreshLanguage()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        I18n.OnChange -= RefreshLanguage;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedSession)
            return;

        _checkedSession = true;

        try
        {
            if (!Session.IsAuthenticated || Session.CurrentUser is null)
            {
                var storedUserId = await BrowserSession.GetUserIdAsync();

                if (storedUserId is null)
                {
                    Nav.NavigateTo("/", forceLoad: true);
                    return;
                }

                var user = await IdentityAccessService.GetByIdAsync(storedUserId.Value);

                if (user is null)
                {
                    await BrowserSession.ClearAsync();
                    Nav.NavigateTo("/", forceLoad: true);
                    return;
                }

                CurrentUserSession.SignIn(user.Id);
                Session.SignIn(user);
            }

            await LoadDevicesAsync();
        }
        catch (Exception ex)
        {
            fatalError = ex.Message;
        }
        finally
        {
            isLoadingPage = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDevicesAsync()
    {
        if (Session.CurrentUser is null)
            return;

        var result = await DeviceManagementService.GetByOwnerAsync(Session.CurrentUser.Id);
        devices = result.ToList();
    }

    private void OpenCreatePanel()
    {
        ResetCreateForm();
        showCreatePanel = true;
    }

    private void CloseCreatePanel()
    {
        showCreatePanel = false;
        errorMessage = string.Empty;
    }

    private async Task CreateDeviceAsync()
    {
        if (Session.CurrentUser is null || isSubmitting)
            return;

        isSubmitting = true;
        errorMessage = string.Empty;

        var result = await DeviceManagementService.RegisterAsync(
            new LowCortisol.Application.Contexts.DeviceManagement.Commands.RegisterDeviceCommand
            {
                OwnerUserId = Session.CurrentUser.Id,
                Name = newDeviceName,
                Type = newDeviceType,
                Status = newDeviceStatus,
                Location = newDeviceLocation,
                ThresholdValue = newThresholdValue,
                ThresholdUnit = newThresholdUnit
            });

        if (!result.Success)
        {
            errorMessage = string.IsNullOrWhiteSpace(result.Error)
                ? "Unable to create device."
                : result.Error;

            isSubmitting = false;
            return;
        }

        showCreatePanel = false;
        ResetCreateForm();
        await LoadDevicesAsync();
        isSubmitting = false;
    }

    private async Task ChangeStatusAsync(Guid deviceId, string status)
    {
        var result = await DeviceManagementService.UpdateStatusAsync(
            new LowCortisol.Application.Contexts.DeviceManagement.Commands.UpdateDeviceStatusCommand
            {
                DeviceId = deviceId,
                Status = status
            });

        if (!result.Success)
        {
            errorMessage = string.IsNullOrWhiteSpace(result.Error)
                ? "Unable to update device status."
                : result.Error;
            return;
        }

        await LoadDevicesAsync();
    }

    private string FormatThreshold(LowCortisol.Application.Contexts.DeviceManagement.DTOs.DeviceDto device)
    {
        return device.ThresholdValue.HasValue && !string.IsNullOrWhiteSpace(device.ThresholdUnit)
            ? $"{device.ThresholdValue.Value} {device.ThresholdUnit}"
            : I18n["devices.notConfigured"];
    }

    private string TranslateDeviceStatus(string status)
    {
        return status switch
        {
            "Online" => I18n["status.online"],
            "Offline" => I18n["status.offline"],
            "Maintenance" => I18n["status.maintenance"],
            _ => status
        };
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Online" => "status-pill status-ok",
            "Offline" => "status-pill status-pending",
            "Maintenance" => "status-pill status-high",
            _ => "status-pill"
        };
    }

    private void ResetCreateForm()
    {
        newDeviceName = string.Empty;
        newDeviceType = "SmartValve";
        newDeviceStatus = "Online";
        newDeviceLocation = string.Empty;
        newThresholdValue = null;
        newThresholdUnit = string.Empty;
    }
}