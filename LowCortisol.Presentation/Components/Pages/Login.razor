@page "/"
@implements IDisposable
@rendermode InteractiveServer
@inject LowCortisol.Presentation.Services.BrowserSessionService BrowserSession
@inject LowCortisol.Application.Contexts.IdentityAccess.Services.IIdentityAccessService IdentityAccessService
@inject LowCortisol.Infrastructure.Security.CurrentUserSession CurrentUserSession
@inject LowCortisol.Presentation.Services.UiSessionService Session
@inject LowCortisol.Presentation.Services.I18nService I18n
@inject NavigationManager Nav

<div class="auth-wrap">
    <div class="soft-card auth-card">
        <h1 class="page-title">@I18n["auth.login.title"]</h1>
        <p class="page-subtitle">@I18n["auth.login.subtitle"]</p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.email"]</label>
            <input class="auth-input"
                   @bind="email"
                   @bind:event="oninput"
                   placeholder="@I18n["auth.login.emailPlaceholder"]" />
        </div>

        <div class="auth-field">
            <label class="auth-label">@I18n["auth.password"]</label>
            <input class="auth-input"
                   type="password"
                   @bind="password"
                   @bind:event="oninput"
                   placeholder="@I18n["auth.login.passwordPlaceholder"]" />
        </div>

        <button class="primary-btn" @onclick="SignInAsync">
            @I18n["auth.signin"]
        </button>

        <a class="secondary-link" href="/register">
            @I18n["auth.create"]
        </a>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;
    private bool isSubmitting;
    private bool _checkedSession;

    protected override void OnInitialized()
    {
        I18n.OnChange += RefreshLanguage;
    }

    private void RefreshLanguage()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        I18n.OnChange -= RefreshLanguage;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedSession)
            return;

        _checkedSession = true;

        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/home", forceLoad: true);
            return;
        }

        var storedUserId = await BrowserSession.GetUserIdAsync();
        if (storedUserId is null)
            return;

        var user = await IdentityAccessService.GetByIdAsync(storedUserId.Value);
        if (user is null)
        {
            await BrowserSession.ClearAsync();
            return;
        }

        CurrentUserSession.SignIn(user.Id);
        Session.SignIn(user);

        Nav.NavigateTo("/home", forceLoad: true);
    }

    private async Task SignInAsync()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        errorMessage = string.Empty;

        try
        {
            var result = await IdentityAccessService.LoginAsync(
                new LowCortisol.Application.Contexts.IdentityAccess.Commands.LoginUserCommand
                {
                    Email = email,
                    Password = password
                });

            if (!result.Success || result.User is null)
            {
                errorMessage = string.IsNullOrWhiteSpace(result.Error)
                    ? "Unable to sign in."
                    : result.Error;
                return;
            }

            CurrentUserSession.SignIn(result.User.Id);
            Session.SignIn(result.User);
            await BrowserSession.SaveUserIdAsync(result.User.Id);

            Nav.NavigateTo("/home", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}