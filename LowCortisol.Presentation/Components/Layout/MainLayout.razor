@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@inject LowCortisol.Presentation.Services.UiSessionService Session
@inject LowCortisol.Presentation.Services.I18nService I18n

<div class="page-shell">
    <div class="topbar">
        <div class="lang-switch">
            <button class="@GetLangButtonClass("es")" @onclick='() => SetLanguage("es")'>ES</button>
            <button class="@GetLangButtonClass("en")" @onclick='() => SetLanguage("en")'>EN</button>
            <button class="@GetLangButtonClass("pt")" @onclick='() => SetLanguage("pt")'>PT</button>
        </div>
    </div>

    <main class="page-content">
        @Body
    </main>

    @if (!IsPublicPage())
    {
        <nav class="bottom-nav">
            <NavLink href="/home" class="nav-item" Match="NavLinkMatch.All">@I18n["nav.home"]</NavLink>
            <NavLink href="/devices" class="nav-item">@I18n["nav.devices"]</NavLink>
            <NavLink href="/reports" class="nav-item">@I18n["nav.reports"]</NavLink>
            <NavLink href="/alerts" class="nav-item">@I18n["nav.alerts"]</NavLink>
            <NavLink href="/profile" class="nav-item">@I18n["nav.profile"]</NavLink>
        </nav>
    }
</div>

@code {
    private bool _languageInitialized;

    protected override void OnInitialized()
    {
        Session.OnChange += Refresh;
        I18n.OnChange += Refresh;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _languageInitialized)
            return;

        _languageInitialized = true;
        await I18n.InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private Task SetLanguage(string language) => I18n.SetLanguageAsync(language);

    private string GetLangButtonClass(string language)
    {
        return I18n.CurrentLanguage == language ? "lang-btn active" : "lang-btn";
    }

    private bool IsPublicPage()
    {
        var path = new Uri(Nav.Uri).AbsolutePath.ToLowerInvariant();
        return path == "/" || path == "/register";
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Session.OnChange -= Refresh;
        I18n.OnChange -= Refresh;
    }
}